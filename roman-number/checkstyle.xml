<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <module name="RegexpHeader">
        <property name="header"
            value="////////////////////////////////////////////////////////////////////\n// PIETRO BROCADELLO 2147994\n// RICCARDO CONTE 2145596\n////////////////////////////////////////////////////////////////////"/>
        <property name="fileExtensions" value="java"/>
    </module>
    <!-- Lunghezza massima del file -->
    <module name="FileLength">
        <property name="max" value="500"/>
    </module>
    <!-- Niente tab nel codice, solo spazi -->
    <module name="FileTabCharacter"/>
    <!-- Lunghezza massima di una riga -->
    <module name="LineLength">
        <property name="max" value="100"/>
    </module>
    <module name="TreeWalker">
        <!-- Complessità delle espressioni booleane -->
        <module name="BooleanExpressionComplexity">
            <property name="max" value="3"/>
        </module>
        <!-- Complessità ciclomatica -->
        <module name="CyclomaticComplexity">
            <property name="max" value="10"/>
        </module>
        <!-- Lunghezza massima di un metodo -->
        <module name="MethodLength">
            <property name="max" value="50"/>
        </module>
        <!-- Niente catch vuoti -->
        <module name="EmptyCatchBlock"/>
        <!-- Niente import con * -->
        <module name="AvoidStarImport"/>
        <!-- Niente import illegali (es. sun.*) -->
        <module name="IllegalImport"/>
        <!-- Le parentesi graffe sono obbligatorie per if/for/while/do -->
        <module name="NeedBraces"/>

    </module>

</module>